      "typeVersion": 1,
      "position": [
        256,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const personen = [\n  { name: 'Anna', alter: 25, stadt: 'Berlin' },\n  { name: 'Max', alter: 30, stadt: 'München' },\n  { name: 'Lisa', alter: 28, stadt: 'Hamburg' },\n  { name: 'Tom', alter: 35, stadt: 'Köln' }\n];\n\nreturn [{ personen }];"
      },
